# ─── App ──────────────────────────────────────────────
APP_URL=http://localhost:3000
APP_NAME=Linkdung

# ─── GraphQL / Apollo ─────────────────────────────────
GRAPHQL_ENDPOINT=https://linkdung-service-nolepdev.koyeb.app/query
GRAPHQL_WS_ENDPOINT=ws://localhost:4000/graphql

# ─── Auth ─────────────────────────────────────────────
JWT_SECRET=change-this-in-production

# ─── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/linkdung

# ─── API ──────────────────────────────────────────────
API_BASE=/api

# ─── Vercel (for production) ──────────────────────────
# Set env vars in the Vercel dashboard (Project → Settings → Environment Variables)
# VERCEL_PROJECT_ID=your-project-id
# VERCEL_ORG_ID=your-org-id
